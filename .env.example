# Copy this file to .env.local for local development.
# In production these are set via GitHub Actions secrets/variables.

# When hosting at https://irakozej.github.io/WIKIMEDIA-Rwanda/, leave unset.
# When moving to a custom domain like https://wikimedia.rw, set this to "".
# NEXT_PUBLIC_BASE_PATH=

# Web3Forms access key (https://web3forms.com — free tier, paste the access key here).
# When unset, forms simulate a successful submission so the UI still works.
# NEXT_PUBLIC_WEB3FORMS_KEY=

# Plausible analytics domain (e.g. wikimedia.rw). When unset, Plausible is not loaded.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
